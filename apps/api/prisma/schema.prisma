// FARMORA — PostgreSQL schema (full platform; Phase 1 APIs: auth + users)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SELLER
  BUYER
  TRANSPORTER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum OtpPurpose {
  LOGIN
  REGISTER
  PASSWORD_RESET
}

enum OrderStatus {
  DRAFT
  REQUESTED
  SELLER_ACCEPTED
  BUYER_CONFIRMED
  TRANSPORT_PENDING
  TRANSPORT_ASSIGNED
  PAID_ESCROW
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
}

enum EscrowStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  phone        String     @unique @db.VarChar(20)
  email        String?    @unique @db.VarChar(255)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  role         UserRole
  status       UserStatus @default(PENDING_VERIFICATION)
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  profile        UserProfile?
  otpChallenges  OtpChallenge[]
  refreshTokens  RefreshToken[]
  sessions       Session[]
  auditLogs      AuditLog[]

  listingsAsSeller   CropListing[]     @relation("SellerListings")
  purchaseRequests   PurchaseRequest[] @relation("BuyerRequests")
  ordersAsBuyer      Order[]           @relation("BuyerOrders")
  ordersAsSeller     Order[]           @relation("SellerOrders")
  transportJobs      TransportJob[]    @relation("TransporterJobs")
  ratingsGiven       Rating[]          @relation("RatingsGiven")
  ratingsReceived    Rating[]          @relation("RatingsReceived")
  disputesRaised     Dispute[]         @relation("DisputesRaised")

  @@index([role, status])
  @@map("users")
}

model UserProfile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  fullName     String   @map("full_name") @db.VarChar(120)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  businessName String?  @map("business_name") @db.VarChar(200)
  bio          String?  @db.VarChar(500)
  state        String   @db.VarChar(80)
  district     String   @db.VarChar(80)
  pincode      String   @db.VarChar(6)
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([state, district])
  @@map("user_profiles")
}

model OtpChallenge {
  id         String     @id @default(uuid()) @db.Uuid
  phone      String     @db.VarChar(20)
  codeHash   String     @map("code_hash") @db.VarChar(255)
  purpose    OtpPurpose
  attempts   Int        @default(0)
  verified   Boolean    @default(false)
  expiresAt  DateTime   @map("expires_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  userId     String?    @map("user_id") @db.Uuid

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, purpose, expiresAt])
  @@map("otp_challenges")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  familyId   String    @map("family_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  userAgent  String?   @map("user_agent") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  refreshId  String?   @unique @map("refresh_id") @db.Uuid
  deviceName String?   @map("device_name") @db.VarChar(200)
  userAgent  String?   @map("user_agent") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  lastActive DateTime  @default(now()) @map("last_active")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String?  @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.VarChar(100)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// --- Phase 2+ models (schema ready; APIs in later phases) ---

model CropListing {
  id          String        @id @default(uuid()) @db.Uuid
  sellerId    String        @map("seller_id") @db.Uuid
  cropName    String        @map("crop_name") @db.VarChar(100)
  variety     String        @db.VarChar(100)
  quantity    Decimal       @db.Decimal(12, 3)
  unit        String        @db.VarChar(20)
  grade       String        @db.VarChar(50)
  harvestDate DateTime      @map("harvest_date") @db.Date
  pricePerUnit Decimal      @map("price_per_unit") @db.Decimal(14, 2)
  currency    String        @default("INR") @db.VarChar(3)
  status      ListingStatus @default(DRAFT)
  state       String        @db.VarChar(80)
  district    String        @db.VarChar(80)
  pincode     String        @db.VarChar(6)
  latitude    Decimal?      @db.Decimal(10, 7)
  longitude   Decimal?      @db.Decimal(10, 7)
  imageUrls   String[]      @map("image_urls")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  seller  User              @relation("SellerListings", fields: [sellerId], references: [id])
  requests PurchaseRequest[]

  @@index([sellerId, status])
  @@index([cropName, status])
  @@index([state, district])
  @@map("crop_listings")
}

model PurchaseRequest {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  buyerId   String   @map("buyer_id") @db.Uuid
  quantity  Decimal  @db.Decimal(12, 3)
  message   String?  @db.VarChar(500)
  status    String   @default("PENDING") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing CropListing @relation(fields: [listingId], references: [id])
  buyer   User        @relation("BuyerRequests", fields: [buyerId], references: [id])
  order   Order?

  @@index([listingId, status])
  @@index([buyerId])
  @@map("purchase_requests")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  purchaseRequestId String      @unique @map("purchase_request_id") @db.Uuid
  buyerId           String      @map("buyer_id") @db.Uuid
  sellerId          String      @map("seller_id") @db.Uuid
  status            OrderStatus @default(REQUESTED)
  cropAmount        Decimal     @map("crop_amount") @db.Decimal(14, 2)
  transportFee      Decimal?    @map("transport_fee") @db.Decimal(14, 2)
  platformFee       Decimal?    @map("platform_fee") @db.Decimal(14, 2)
  currency          String      @default("INR") @db.VarChar(3)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  buyer           User            @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller          User            @relation("SellerOrders", fields: [sellerId], references: [id])
  transportJob    TransportJob?
  escrow          EscrowAccount?
  shipment        Shipment?
  disputes        Dispute[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@map("orders")
}

model TransportJob {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @unique @map("order_id") @db.Uuid
  transporterId  String?  @map("transporter_id") @db.Uuid
  status         String   @default("PENDING") @db.VarChar(30)
  pickupLat      Decimal? @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng      Decimal? @map("pickup_lng") @db.Decimal(10, 7)
  dropLat        Decimal? @map("drop_lat") @db.Decimal(10, 7)
  dropLng        Decimal? @map("drop_lng") @db.Decimal(10, 7)
  acceptedAt     DateTime? @map("accepted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  order       Order @relation(fields: [orderId], references: [id])
  transporter User? @relation("TransporterJobs", fields: [transporterId], references: [id])

  @@index([transporterId, status])
  @@map("transport_jobs")
}

model EscrowAccount {
  id        String       @id @default(uuid()) @db.Uuid
  orderId   String       @unique @map("order_id") @db.Uuid
  status    EscrowStatus @default(PENDING)
  totalAmount Decimal    @map("total_amount") @db.Decimal(14, 2)
  currency  String       @default("INR") @db.VarChar(3)
  fundedAt  DateTime?    @map("funded_at")
  releasedAt DateTime?   @map("released_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  order   Order          @relation(fields: [orderId], references: [id])
  entries LedgerEntry[]

  @@map("escrow_accounts")
}

model LedgerEntry {
  id          String   @id @default(uuid()) @db.Uuid
  escrowId    String   @map("escrow_id") @db.Uuid
  entryType   String   @map("entry_type") @db.VarChar(50)
  amount      Decimal  @db.Decimal(14, 2)
  direction   String   @db.VarChar(10)
  reference   String?  @db.VarChar(100)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  escrow EscrowAccount @relation(fields: [escrowId], references: [id])

  @@index([escrowId, createdAt])
  @@map("ledger_entries")
}

model Shipment {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @unique @map("order_id") @db.Uuid
  status    String   @default("PENDING") @db.VarChar(30)
  eta       DateTime?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order      Order       @relation(fields: [orderId], references: [id])
  gpsPoints  GpsPoint[]

  @@map("shipments")
}

model GpsPoint {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  recordedAt DateTime @default(now()) @map("recorded_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, recordedAt])
  @@map("gps_points")
}

model Rating {
  id         String   @id @default(uuid()) @db.Uuid
  fromUserId String   @map("from_user_id") @db.Uuid
  toUserId   String   @map("to_user_id") @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  score      Int
  comment    String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUser   User @relation("RatingsReceived", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId, orderId])
  @@index([toUserId])
  @@map("ratings")
}

model Dispute {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @map("order_id") @db.Uuid
  raisedById  String        @map("raised_by_id") @db.Uuid
  type        String        @db.VarChar(50)
  description String        @db.VarChar(2000)
  status      DisputeStatus @default(OPEN)
  evidenceUrls String[]     @map("evidence_urls")
  resolution  String?       @db.VarChar(2000)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  order    Order @relation(fields: [orderId], references: [id])
  raisedBy User  @relation("DisputesRaised", fields: [raisedById], references: [id])

  @@index([orderId, status])
  @@map("disputes")
}

model CropPriceSnapshot {
  id         String   @id @default(uuid()) @db.Uuid
  cropName   String   @map("crop_name") @db.VarChar(100)
  marketName String   @map("market_name") @db.VarChar(150)
  state      String   @db.VarChar(80)
  minPrice   Decimal  @map("min_price") @db.Decimal(14, 2)
  maxPrice   Decimal  @map("max_price") @db.Decimal(14, 2)
  modalPrice Decimal  @map("modal_price") @db.Decimal(14, 2)
  unit       String   @db.VarChar(20)
  source     String   @db.VarChar(50)
  recordedOn DateTime @map("recorded_on") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([cropName, marketName, recordedOn, source])
  @@index([cropName, state, recordedOn])
  @@map("crop_price_snapshots")
}
