# Copy to apps/api/.env and apps/web/.env.local

# Database
DATABASE_URL=postgresql://farmora:farmora_dev_secret@localhost:5432/farmora?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_PHONE=5
OTP_RATE_LIMIT_WINDOW_SECONDS=3600

# App
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:3000

# AgriPay / Payments
PAYMENT_PROVIDER=MOCK
MOCK_PAYMENTS=true
PLATFORM_FEE_PERCENT=2.5
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Transport matching
TRANSPORT_MATCH_RADIUS_KM=100
TRANSPORT_BASE_FEE_INR=500
TRANSPORT_PER_KM_INR=15

# Next.js public
NEXT_PUBLIC_API_URL=http://localhost:4000
